{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "IRONWOOD FRAMEWORK v3.1 — Claude Code hook configuration. require-pr.sh blocks direct push to main (forcing branch+PR workflow). protect-files.sh blocks edits to DO NOT TOUCH paths. session-end.sh auto-appends sessions to PROJECT_MANIFEST.md with branch + PR info.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/require-pr.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
