# Sideline Setups — client environment variables (Vite)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# These are exposed to the browser, so only anon/publishable keys belong here.

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Server-side secrets (SUPABASE_SERVICE_ROLE_KEY, Square keys, SMS provider keys)
# are configured in Supabase Edge Function secrets, NOT here.
